# Neon pooled connection URL (enable Connection pooling in Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15&pool_timeout=15&connection_limit=5"
# Neon direct connection URL (disable Connection pooling in Neon)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"
PORT=3001
CLIENT_ORIGIN="http://127.0.0.1:4173"
JWT_SECRET="replace-with-a-long-random-secret"
NODE_ENV="development"
